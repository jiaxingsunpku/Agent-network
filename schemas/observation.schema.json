{
  "$defs": {
    "Approach": {
      "additionalProperties": false,
      "description": "单进口方向的一次采样观测（docs/world-status.md §2）。",
      "properties": {
        "direction": {
          "$ref": "#/$defs/Direction"
        },
        "vehicle_count": {
          "minimum": 0,
          "title": "Vehicle Count",
          "type": "integer"
        },
        "halting_count": {
          "minimum": 0,
          "title": "Halting Count",
          "type": "integer"
        },
        "mean_speed_mps": {
          "minimum": 0,
          "title": "Mean Speed Mps",
          "type": "number"
        },
        "mean_delay_sec": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Mean Delay Sec"
        }
      },
      "required": [
        "direction",
        "vehicle_count",
        "halting_count",
        "mean_speed_mps"
      ],
      "title": "Approach",
      "type": "object"
    },
    "Direction": {
      "description": "路口进口方向（docs/world-status.md §2）。",
      "enum": [
        "north",
        "south",
        "east",
        "west"
      ],
      "title": "Direction",
      "type": "string"
    },
    "SimClock": {
      "additionalProperties": false,
      "description": "仿真时钟（task5 双时间戳地基）：边缘仿真器(SUMO)的自有时钟，与 envelope.time.event_ts\n(挂钟)并存，作为异步控制回路的对齐/过期判据。完整的世界-边缘时钟同步留作未来一等公民问题。",
      "properties": {
        "sim_time": {
          "minimum": 0,
          "title": "Sim Time",
          "type": "number"
        },
        "sim_step": {
          "minimum": 0,
          "title": "Sim Step",
          "type": "integer"
        }
      },
      "required": [
        "sim_time",
        "sim_step"
      ],
      "title": "SimClock",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "observation_type": {
      "const": "traffic.intersection",
      "default": "traffic.intersection",
      "title": "Observation Type",
      "type": "string"
    },
    "intersection_id": {
      "minLength": 1,
      "title": "Intersection Id",
      "type": "string"
    },
    "approaches": {
      "items": {
        "$ref": "#/$defs/Approach"
      },
      "minItems": 1,
      "title": "Approaches",
      "type": "array"
    },
    "sim_clock": {
      "anyOf": [
        {
          "$ref": "#/$defs/SimClock"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "required": [
    "intersection_id",
    "approaches"
  ],
  "title": "交通路口观测 payload（docs/world-status.md §2）",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
